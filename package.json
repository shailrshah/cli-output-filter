{
  "name": "@shailrshah/cli-output-filter",
  "version": "1.0.1",
  "description": "A CLI tool for filtering repetitive output from commands while preserving important information",
  "license": "MIT",
  "author": "shailrshah",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
